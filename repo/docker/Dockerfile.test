# Toolchain image for running repo/run_tests.sh (Maven backend tests + npm/Vitest frontend + shell unit_tests).
# Build context: repository root (same as Dockerfile.backend).
FROM maven:3.9-eclipse-temurin-17

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        gnupg \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
ENV CI=true
# Default: API curl tests target host port 8080 (backend published on host). Override when using compose network.
ENV API_BASE_URL=http://host.docker.internal:8080
